{
  "name": "molecular-viewer",
  "displayName": "Molecular Viewer",
  "description": "3D molecular structure viewer and editor for computational chemistry files (Gaussian .gjf/.log, ORCA .inp/.out, .xyz, .mol2, .coord, .mol, .sdf). Features ball-and-stick rendering, auto bond detection, interactive rotation/zoom, bond length/angle/dihedral editing, atom add/delete, optimization trajectory navigation, and save-as — like GaussView in your IDE.",
  "version": "0.6.2",
  "publisher": "Atreides-Jimmy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Atreides-Jimmy/Molecular-Viewer-on-VScode.git"
  },
  "bugs": {
    "url": "https://github.com/Atreides-Jimmy/Molecular-Viewer-on-VScode/issues"
  },
  "homepage": "https://github.com/Atreides-Jimmy/Molecular-Viewer-on-VScode#readme",
  "keywords": [
    "chemistry",
    "molecular",
    "3d",
    "gaussian",
    "gjf",
    "xyz",
    "visualization",
    "computational chemistry",
    "gaussview",
    "molecule",
    "molecular editor",
    "bond length",
    "dihedral",
    "mol2",
    "gaussian log",
    "orca",
    "coord",
    "optimization"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Visualization",
    "Science"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onCustomEditor:molecularViewer.editor",
    "onCommand:molecularViewer.openViewer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "molecularViewer.openViewer",
        "title": "Molecular Viewer: Open 3D Viewer",
        "icon": "$(eye)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "molecularViewer.openViewer",
          "when": "resourceExtname == .gjf || resourceExtname == .xyz || resourceExtname == .mol || resourceExtname == .sdf || resourceExtname == .com || resourceExtname == .gjf03 || resourceExtname == .gjf09 || resourceExtname == .gjf16 || resourceExtname == .mol2 || resourceExtname == .log || resourceExtname == .out || resourceExtname == .coord || resourceExtname == .inp",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "molecularViewer.openViewer",
          "when": "resourceExtname == .gjf || resourceExtname == .xyz || resourceExtname == .mol || resourceExtname == .sdf || resourceExtname == .com || resourceExtname == .gjf03 || resourceExtname == .gjf09 || resourceExtname == .gjf16 || resourceExtname == .mol2 || resourceExtname == .log || resourceExtname == .out || resourceExtname == .coord || resourceExtname == .inp",
          "group": "navigation"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "molecularViewer.editor",
        "displayName": "Molecular 3D Viewer",
        "selector": [
          {
            "filenamePattern": "*.gjf"
          },
          {
            "filenamePattern": "*.xyz"
          },
          {
            "filenamePattern": "*.mol"
          },
          {
            "filenamePattern": "*.sdf"
          },
          {
            "filenamePattern": "*.com"
          },
          {
            "filenamePattern": "*.gjf03"
          },
          {
            "filenamePattern": "*.gjf09"
          },
          {
            "filenamePattern": "*.gjf16"
          },
          {
            "filenamePattern": "*.mol2"
          },
          {
            "filenamePattern": "*.log"
          },
          {
            "filenamePattern": "*.out"
          },
          {
            "filenamePattern": "*.coord"
          },
          {
            "filenamePattern": "*.inp"
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
